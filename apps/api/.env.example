# Runtime
PORT=4000
NODE_ENV=development

# Database
# Bootstrap uses 5434 by default so it can run beside projects that use 5433.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/bootstrap

# Auth and sessions
JWT_SECRET=change-me-in-production
# Optional. Leave blank for local localhost/LAN development so browsers keep host-only cookies.
COOKIE_DOMAIN=

# URLs and CORS
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
