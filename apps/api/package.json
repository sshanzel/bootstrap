{
  "name": "@bootstrap/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node --import @swc-node/register/esm-register src/main.ts",
    "typecheck": "tsc --noEmit",
    "dev": "node --watch --import @swc-node/register/esm-register src/main.ts",
    "typeorm": "node --import @swc-node/register/esm-register node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm migration:generate -d src/db/typeorm.config.ts",
    "migration:run": "pnpm typeorm migration:run -d src/db/typeorm.config.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/db/typeorm.config.ts",
    "lint": "eslint src/",
    "lint:ci": "eslint src/ --max-warnings 0",
    "test:smoke": "node --import @swc-node/register/esm-register src/test/smoke-app-module.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@bootstrap/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.5.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.31",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.3.0",
    "@nestjs/testing": "^11.1.17",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "typescript-eslint": "^8.56.1"
  }
}
